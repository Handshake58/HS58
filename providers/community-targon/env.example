# === REQUIRED ===
PROVIDER_PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY
TARGON_API_KEY=your-targon-api-key

# === TARGON ===
TARGON_API_URL=https://api.targon.com/v1

# === DRAIN / BLOCKCHAIN ===
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=137
CLAIM_THRESHOLD=10000000
AUTO_CLAIM_INTERVAL_MINUTES=10
AUTO_CLAIM_BUFFER_SECONDS=3600
STORAGE_PATH=./data/vouchers.json

# === SERVER ===
PORT=3000
HOST=0.0.0.0
PROVIDER_NAME=Community-Targon

# === PRICING ===
# Markup on Targon base prices (50% = 1.5x)
MARKUP_PERCENT=50
# Fallback prices per million tokens if Targon API doesn't return pricing
DEFAULT_INPUT_PRICE_PER_M=0.50
DEFAULT_OUTPUT_PRICE_PER_M=1.50
# How often to refresh models and pricing from Targon (seconds)
PRICING_REFRESH_INTERVAL=3600

# === OPTIONAL ===
ADMIN_PASSWORD=

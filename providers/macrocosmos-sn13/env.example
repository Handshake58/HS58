# === Macrocosmos SN13 API Key (required) ===
MACROCOSMOS_API_KEY=your_api_key_here

# === DRAIN Payment Config (required) ===
PROVIDER_PRIVATE_KEY=0x...

# Recommended: Reliable Polygon RPC (free at alchemy.com or infura.io)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# === Pricing (optional, defaults shown) ===
# Price per social data query in USD (default: $0.003)
PRICE_PER_SOCIAL_QUERY=0.003

# Price per scraping task in USD (default: $0.005)
PRICE_PER_SCRAPING_TASK=0.005

# Markup multiplier as percent (e.g. 50 = 1.5x = 50% profit margin)
MARKUP_PERCENT=50

# === Limits (optional, defaults shown) ===
# Max requests per minute per payment channel
RATE_LIMIT_PER_MINUTE=10

# === Admin (optional) ===
# Password for /v1/admin/* endpoints (empty = no auth)
ADMIN_PASSWORD=

# === Optional (defaults shown) ===
PORT=3000
CHAIN_ID=137
CLAIM_THRESHOLD=1000000
PROVIDER_NAME=Macrocosmos-SN13
AUTO_CLAIM_INTERVAL_MINUTES=10
AUTO_CLAIM_BUFFER_SECONDS=3600
STORAGE_PATH=./data/vouchers.json
